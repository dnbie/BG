# Groq API key for the /api/ai serverless function.
# Get one free at https://console.groq.com/keys
# For local development: copy this file to ".env" and paste your key.
# For production: set these in your Vercel project's Environment Variables (do NOT commit .env).
GROQ_API_KEY="your_groq_api_key_here"

# Optional — override the default model.
# GROQ_MODEL="llama-3.3-70b-versatile"
